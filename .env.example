# =============================================================================
# Auto Forex Trading System - Environment Variables
# =============================================================================
# This file contains ONLY secrets and passwords.
# All other configuration is in backend/config/config.yaml (or config.dev.yaml)
# =============================================================================

# Database Credentials (Required)
DB_PASSWORD=your_secure_database_password

# Django Secret Key (Required)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your_django_secret_key

# JWT Secret Key (Required - MUST be different from SECRET_KEY)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your_jwt_secret_key

# OANDA API Token Encryption Key (Required in production)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OANDA_TOKEN_ENCRYPTION_KEY=your_fernet_key_for_oanda_tokens

# Optional comma-separated fallback Fernet keys used only during key rotation
OANDA_TOKEN_ENCRYPTION_FALLBACK_KEYS=

# Redis Password (Optional - leave empty for no password)
REDIS_PASSWORD=your_redis_password

# =============================================================================
# Daily Tick Data Loading (Optional - Athena)
# =============================================================================
# When set, the Celery Beat scheduler runs load_data daily at 02:00 UTC
# to fetch the previous day's tick data from AWS Athena.
# If LOAD_DATA_DATABASE is empty or unset, the task is silently skipped.

# Athena database and table (required to enable daily loading)
LOAD_DATA_DATABASE=
LOAD_DATA_TABLE=

# Instrument/ticker to load (default: C:USD-JPY)
LOAD_DATA_INSTRUMENT=C:USD-JPY

# AWS profile name (optional - uses default credentials if empty)
LOAD_DATA_AWS_PROFILE=

# IAM role ARN to assume before querying Athena (optional)
LOAD_DATA_ROLE_ARN=

# S3 bucket for Athena query results (optional)
LOAD_DATA_OUTPUT_BUCKET=

# =============================================================================
# Database Backup to S3 (Optional)
# =============================================================================
# When set, the Celery Beat scheduler runs a daily backup at 03:00 UTC.
# pg_dump output is always saved locally under ./backups/.
# If DB_BACKUP_S3_BUCKET is set, the backup is also uploaded to S3.

# S3 bucket for backup uploads (leave empty for local-only backups)
DB_BACKUP_S3_BUCKET=

# S3 key prefix (default: db-backups/)
DB_BACKUP_S3_PREFIX=db-backups/

# IAM role ARN to assume before uploading to S3 (optional)
DB_BACKUP_ROLE_ARN=

# AWS profile name (optional - uses default credentials if empty)
DB_BACKUP_AWS_PROFILE=

# Number of days to keep local backups (default: 7)
DB_BACKUP_RETENTION_DAYS=7
