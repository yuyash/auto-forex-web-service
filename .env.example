# =============================================================================
# Auto Forex Trading System - Environment Variables
# =============================================================================
# This file contains ONLY secrets and passwords.
# All other configuration is in backend/config/config.yaml (or config.dev.yaml)
# =============================================================================

# Database Credentials (Required)
DB_PASSWORD=your_secure_database_password

# Optional database client name shown in pg_stat_activity.
# In Docker Compose this is set per service, so you usually don't need to override it.
DB_APPLICATION_NAME=

# Backend DB connection lifetime in seconds. Production defaults to 0 in
# docker-compose.prod.yaml so ASGI request handlers do not retain idle
# PostgreSQL connections after long-lived browser requests.
DB_CONN_MAX_AGE=0

# Django Secret Key (Required)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your_django_secret_key

# JWT Secret Key (Required - MUST be different from SECRET_KEY)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your_jwt_secret_key

# OANDA API Token Encryption Key (Required in production)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OANDA_TOKEN_ENCRYPTION_KEY=your_fernet_key_for_oanda_tokens

# Optional comma-separated fallback Fernet keys used only during key rotation
OANDA_TOKEN_ENCRYPTION_FALLBACK_KEYS=

# Redis Password (Optional - leave empty for no password)
REDIS_PASSWORD=your_redis_password

# =============================================================================
# Browser Origin / Vite Development Access (Optional)
# =============================================================================
# Comma-separated SPA origins allowed to call the backend with credentials.
# Add the Vite origin only when you intentionally want a local Vite app to call
# this backend directly, e.g. for production-data UI debugging.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Origins trusted by Django's CSRF checker. Keep this aligned with
# CORS_ALLOWED_ORIGINS for credentialed browser clients.
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Backend CIDRs allowed to supply X-Forwarded-For/X-Real-IP. Keep this limited
# to reverse proxies and load balancers. Docker Compose defaults include the
# local Docker bridge range; add your load balancer CIDR if it sits before Nginx.
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128,172.16.0.0/12

# For direct cross-site Vite -> production API cookie refresh flows, use:
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174
# CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174
# AUTH_ACCESS_COOKIE_SAMESITE=None
# AUTH_REFRESH_COOKIE_SAMESITE=None
# AUTH_ACCESS_COOKIE_SECURE=true
# AUTH_REFRESH_COOKIE_SECURE=true

# =============================================================================
# Celery Worker Topology (Optional)
# =============================================================================
# Queue isolation defaults are defined in Docker Compose. Override only if needed.
CELERY_DEFAULT_WORKER_CONCURRENCY=2
CELERY_CONTROL_WORKER_CONCURRENCY=2
CELERY_MARKET_WORKER_CONCURRENCY=3
CELERY_BACKTEST_WORKER_CONCURRENCY=4
CELERY_BACKTEST_PUBLISHER_CONCURRENCY=4
CELERY_TRADING_WORKER_CONCURRENCY=2
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# =============================================================================
# OANDA Account Snapshot Refresh (Optional)
# =============================================================================
# Account list/detail endpoints read cached broker snapshots. Celery refreshes
# active accounts on this cadence, and API responses mark snapshots stale after
# the configured age.
OANDA_ACCOUNT_SNAPSHOT_REFRESH_SECONDS=60
OANDA_ACCOUNT_SNAPSHOT_STALE_SECONDS=300

# =============================================================================
# Historical Tick Data Loading (Optional - Athena)
# =============================================================================
# Used by the load_data management command when importing tick data from AWS Athena.

# Athena database and table
LOAD_DATA_DATABASE=
LOAD_DATA_TABLE=

# Instrument/ticker to load (default: C:USD-JPY)
LOAD_DATA_INSTRUMENT=C:USD-JPY

# AWS profile name (optional - uses default credentials if empty)
LOAD_DATA_AWS_PROFILE=

# IAM role ARN to assume before querying Athena (optional)
LOAD_DATA_ROLE_ARN=

# S3 bucket for Athena query results (optional)
LOAD_DATA_OUTPUT_BUCKET=

# =============================================================================
# Database Backup to S3 (Optional)
# =============================================================================
# Used by the backup task implementation if you invoke it manually.
# pg_dump output is always saved locally under ./backups/.
# If DB_BACKUP_S3_BUCKET is set, the backup is also uploaded to S3.

# S3 bucket for backup uploads (leave empty for local-only backups)
DB_BACKUP_S3_BUCKET=

# S3 key prefix (default: db-backups/)
DB_BACKUP_S3_PREFIX=db-backups/

# IAM role ARN to assume before uploading to S3 (optional)
DB_BACKUP_ROLE_ARN=

# AWS profile name (optional - uses default credentials if empty)
DB_BACKUP_AWS_PROFILE=

# Number of days to keep local backups (default: 7)
DB_BACKUP_RETENTION_DAYS=7
