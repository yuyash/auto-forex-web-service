{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django: runserver",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/manage.py",
      "args": [
        "runserver",
        "0.0.0.0:8000"
      ],
      "django": true,
      "justMyCode": false,
      "console": "internalConsole",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DEBUG": "true",
        "DJANGO_SETTINGS_MODULE": "config.settings",
        "DB_HOST": "localhost",
        "DB_APPLICATION_NAME": "auto-forex-vscode-backend",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_DB": "0"
      }
    },
    {
      "name": "Celery: default worker",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": [
        "-A",
        "config",
        "worker",
        "-l",
        "info",
        "-Q",
        "default",
        "--pool=solo",
        "-n",
        "default_worker@%h"
      ],
      "justMyCode": true,
      "console": "internalConsole",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings",
        "DB_HOST": "localhost",
        "DB_APPLICATION_NAME": "auto-forex-vscode-celery-default",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_DB": "0",
        "OBJC_DISABLE_INITIALIZE_FORK_SAFETY": "YES"
      }
    },
    {
      "name": "Celery: trading worker",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": [
        "-A",
        "config",
        "worker",
        "-l",
        "info",
        "-Q",
        "trading",
        "--pool=solo",
        "-n",
        "trading_worker@%h"
      ],
      "justMyCode": true,
      "console": "internalConsole",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings",
        "DB_HOST": "localhost",
        "DB_APPLICATION_NAME": "auto-forex-vscode-celery-trading",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_DB": "0",
        "OBJC_DISABLE_INITIALIZE_FORK_SAFETY": "YES"
      }
    },
    {
      "name": "Celery: market worker",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": [
        "-A",
        "config",
        "worker",
        "-l",
        "info",
        "-Q",
        "market",
        "--pool=solo",
        "-n",
        "market_worker@%h"
      ],
      "justMyCode": true,
      "console": "internalConsole",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings",
        "CELERY_START_MARKET_TICK_SUPERVISOR": "1",
        "DB_HOST": "localhost",
        "DB_APPLICATION_NAME": "auto-forex-vscode-celery-market",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_DB": "0",
        "OBJC_DISABLE_INITIALIZE_FORK_SAFETY": "YES"
      }
    },
    {
      "name": "Celery: backtest worker",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": [
        "-A",
        "config",
        "worker",
        "-l",
        "info",
        "-Q",
        "backtest",
        "--pool=threads",
        "--concurrency=4",
        "-n",
        "backtest_worker@%h"
      ],
      "justMyCode": true,
      "console": "internalConsole",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings",
        "DB_HOST": "localhost",
        "DB_APPLICATION_NAME": "auto-forex-vscode-celery-backtest",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_DB": "0",
        "OBJC_DISABLE_INITIALIZE_FORK_SAFETY": "YES"
      }
    },
    {
      "name": "Celery: backtest publisher",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": [
        "-A",
        "config",
        "worker",
        "-l",
        "info",
        "-Q",
        "backtest_publisher",
        "--pool=threads",
        "--concurrency=4",
        "-n",
        "backtest_publisher@%h"
      ],
      "justMyCode": true,
      "console": "internalConsole",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings",
        "DB_HOST": "localhost",
        "DB_APPLICATION_NAME": "auto-forex-vscode-celery-backtest-publisher",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_DB": "0",
        "OBJC_DISABLE_INITIALIZE_FORK_SAFETY": "YES"
      }
    },
    {
      "name": "Celery: system worker",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": [
        "-A",
        "config",
        "worker",
        "-l",
        "info",
        "-Q",
        "system",
        "--pool=solo",
        "-n",
        "system_worker@%h"
      ],
      "justMyCode": true,
      "console": "internalConsole",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings",
        "CELERY_ENABLE_STARTUP_RECOVERY": "1",
        "DB_HOST": "localhost",
        "DB_APPLICATION_NAME": "auto-forex-vscode-celery-system",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_DB": "0",
        "OBJC_DISABLE_INITIALIZE_FORK_SAFETY": "YES"
      }
    },
    {
      "name": "Celery: beat",
      "type": "debugpy",
      "request": "launch",
      "module": "celery",
      "args": [
        "-A",
        "config",
        "beat",
        "-l",
        "info",
        "--scheduler",
        "django_celery_beat.schedulers:DatabaseScheduler"
      ],
      "justMyCode": true,
      "console": "internalConsole",
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings",
        "DB_HOST": "localhost",
        "DB_APPLICATION_NAME": "auto-forex-vscode-celery-beat",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "REDIS_DB": "0",
        "OBJC_DISABLE_INITIALIZE_FORK_SAFETY": "YES"
      }
    },
    {
      "name": "Frontend: npm run dev",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}/frontend",
      "console": "internalConsole",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ],
  "compounds": [
    {
      "name": "Run App",
      "configurations": [
        "Django: runserver",
        "Celery: beat",
        "Celery: system worker",
        "Celery: default worker",
        "Celery: trading worker",
        "Celery: backtest worker",
        "Celery: backtest publisher",
        "Celery: market worker",
        "Frontend: npm run dev"
      ]
    }
  ]
}
