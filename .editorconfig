# .editorconfig
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{js,jsx,ts,tsx,json,css,md,yaml,yml,html}]
indent_size = 2

[*.py]
indent_size = 4

[Makefile]
indent_style = tab

[*.{dockerfile,Dockerfile}]
indent_size = 4

[docker-compose*.{yaml,yml}]
indent_size = 2
